DATABASE_URL="postgresql://vetflow:vetflow@localhost:5432/vetflow?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="7d"
PORT=4000
NODE_ENV="development"

# AWS Credentials (shared by SES and S3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Email (AWS SES)
AWS_SES_REGION="eu-west-1"
AWS_SES_FROM_EMAIL="noreply@vetflow.co.il"

# SMS Provider (inforumobile | 019)
SMS_PROVIDER="inforumobile"
SMS_API_KEY=""
SMS_SENDER_NAME="VetFlow"

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# File Upload (AWS S3)
AWS_S3_REGION="eu-west-1"
AWS_S3_BUCKET="vetflow-uploads"

# Payment Provider (tranzila | cardcom)
PAYMENT_PROVIDER="tranzila"
TRANZILA_TERMINAL_NAME=""
TRANZILA_TERMINAL_PASSWORD=""
CARDCOM_TERMINAL_NUMBER=""
CARDCOM_API_NAME=""

# App URL (for payment callbacks)
APP_URL="http://localhost:3000"
