generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Multi-Tenant =====

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String
  phone     String?
  address   String?
  logoUrl   String?
  settings  Json     @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  clients      Client[]
  animals      Animal[]
  appointments Appointment[]
  inventory    InventoryItem[]
  suppliers    Supplier[]
  invoices     Invoice[]
  quotes       Quote[]
  reminders    Reminder[]
  messageLogs  MessageLog[]
  labTests     LabTest[]
  dicomStudies DicomStudy[]

  @@map("tenants")
}

// ===== Users =====

enum UserRole {
  owner
  admin
  veterinarian
  technician
  receptionist
}

model User {
  id             String   @id @default(cuid())
  tenantId       String
  email          String
  passwordHash   String
  name           String
  phone          String?
  role           UserRole @default(receptionist)
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments   Appointment[]   @relation("VeterinarianAppointments")
  medicalRecords MedicalRecord[]
  labTests       LabTest[]       @relation("VeterinarianLabTests")
  refreshTokens  RefreshToken[]
  documents      Document[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ===== Clients (Pet Owners) =====

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  firstName String
  lastName  String
  phone     String
  email     String?
  address   String?
  idNumber    String
  dateOfBirth DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  animals      Animal[]
  appointments Appointment[]
  invoices     Invoice[]
  quotes       Quote[]
  messageLogs  MessageLog[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, lastName])
  @@map("clients")
}

// ===== Animals =====

enum AnimalSpecies {
  dog
  cat
  bird
  rabbit
  hamster
  reptile
  fish
  other
}

enum AnimalGender {
  male
  female
  unknown
}

model Animal {
  id              String        @id @default(cuid())
  tenantId        String
  clientId        String
  name            String
  species         AnimalSpecies @default(dog)
  breed           String?
  gender          AnimalGender  @default(unknown)
  dateOfBirth     DateTime?
  weight          Float?
  microchipNumber String?
  imageUrl        String?
  isNeutered      Boolean       @default(false)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  reminders      Reminder[]
  labTests       LabTest[]
  dicomStudies   DicomStudy[]
  documents      Document[]

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, microchipNumber])
  @@map("animals")
}

// ===== Appointments =====

enum AppointmentStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

model Appointment {
  id              String            @id @default(cuid())
  tenantId        String
  clientId        String
  animalId        String
  veterinarianId  String
  startTime       DateTime
  endTime         DateTime
  type            String
  status          AppointmentStatus @default(pending)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  animal        Animal          @relation(fields: [animalId], references: [id], onDelete: Cascade)
  veterinarian  User            @relation("VeterinarianAppointments", fields: [veterinarianId], references: [id])
  medicalRecord MedicalRecord?

  @@index([tenantId])
  @@index([tenantId, veterinarianId, startTime])
  @@index([tenantId, startTime])
  @@map("appointments")
}

// ===== Medical Records =====

model MedicalRecord {
  id              String   @id @default(cuid())
  tenantId        String
  animalId        String
  appointmentId   String?  @unique
  veterinarianId  String
  date            DateTime @default(now())
  diagnosis       String?
  treatment       String?
  prescription    String?
  notes           String?
  weight          Float?
  temperature     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  animal       Animal       @relation(fields: [animalId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])
  veterinarian User         @relation(fields: [veterinarianId], references: [id])

  @@index([tenantId])
  @@index([tenantId, animalId])
  @@map("medical_records")
}

// ===== Inventory =====

enum InventoryCategory {
  medication
  food
  equipment
  supplies
  other
}

model InventoryItem {
  id          String            @id @default(cuid())
  tenantId    String
  name        String
  category    InventoryCategory @default(other)
  sku         String?
  quantity    Int               @default(0)
  minQuantity Int               @default(5)
  unitPrice   Float             @default(0)
  costPrice   Float?
  expiryDate  DateTime?
  supplierId  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  invoiceItems InvoiceItem[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@map("inventory_items")
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     InventoryItem[]

  @@index([tenantId])
  @@map("suppliers")
}

// ===== Invoices =====

enum InvoiceStatus {
  draft
  sent
  paid
  partially_paid
  cancelled
}

enum PaymentMethod {
  cash
  credit_card
  bank_transfer
  check
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  clientId      String
  invoiceNumber String
  status        InvoiceStatus @default(draft)
  subtotal      Float         @default(0)
  taxRate       Float         @default(0.17)
  taxAmount     Float         @default(0)
  total         Float         @default(0)
  paidAmount    Float         @default(0)
  paymentMethod PaymentMethod?
  notes         String?
  issuedAt      DateTime      @default(now())
  dueAt         DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client  Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items   InvoiceItem[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@map("invoices")
}

model InvoiceItem {
  id              String  @id @default(cuid())
  invoiceId       String
  inventoryItemId String?
  description     String
  quantity        Float   @default(1)
  unitPrice       Float
  total           Float

  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@map("invoice_items")
}

// ===== Quotes =====

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

model Quote {
  id          String      @id @default(cuid())
  tenantId    String
  clientId    String
  quoteNumber String
  status      QuoteStatus @default(draft)
  items       Json        @default("[]")
  subtotal    Float       @default(0)
  taxRate     Float       @default(0.17)
  taxAmount   Float       @default(0)
  total       Float       @default(0)
  validUntil  DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@map("quotes")
}

// ===== Reminders =====

enum ReminderType {
  vaccination
  appointment
  follow_up
  custom
}

enum ReminderStatus {
  pending
  sent
  failed
  cancelled
}

model Reminder {
  id         String         @id @default(cuid())
  tenantId   String
  animalId   String?
  type       ReminderType
  status     ReminderStatus @default(pending)
  message    String
  sendAt     DateTime
  sentAt     DateTime?
  channel    String         @default("sms") // sms, email, whatsapp
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  animal Animal? @relation(fields: [animalId], references: [id])

  @@index([tenantId])
  @@index([status, sendAt])
  @@map("reminders")
}

// ===== Treatment Templates =====

model TreatmentTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        String   // vaccination, surgery, checkup, dental, etc.
  items       Json     @default("[]") // [{description, quantity, unitPrice}]
  duration    Int      @default(30) // minutes
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("treatment_templates")
}

// ===== Message Logs =====

model MessageLog {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String?
  channel   String   // sms, email, whatsapp
  recipient String
  subject   String?
  body      String
  status    String   @default("sent")
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@map("message_logs")
}

// ===== Lab Tests =====

enum LabTestStatus {
  pending
  in_progress
  completed
  cancelled
}

model LabTest {
  id              String        @id @default(cuid())
  tenantId        String
  animalId        String
  veterinarianId  String
  medicalRecordId String?
  testType        String        // hematology, biochemistry, urinalysis, cytology, parasitology, serology, other
  panelName       String?       // e.g. "CBC", "Chem 10", "UA"
  status          LabTestStatus @default(pending)
  orderedAt       DateTime      @default(now())
  completedAt     DateTime?
  deviceId        String?       // ID of the lab device (for bridge integration)
  deviceName      String?       // Human-readable device name
  rawData         Json?         // Raw device output (ASTM/HL7 payload)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  animal       Animal          @relation(fields: [animalId], references: [id], onDelete: Cascade)
  veterinarian User            @relation("VeterinarianLabTests", fields: [veterinarianId], references: [id])
  results      LabTestResult[]

  @@index([tenantId])
  @@index([tenantId, animalId])
  @@index([tenantId, status])
  @@map("lab_tests")
}

model LabTestResult {
  id        String  @id @default(cuid())
  labTestId String
  paramName String  // e.g., WBC, RBC, Glucose, BUN, ALT
  value     String  // actual measured value
  unit      String  // e.g., g/dL, 10^3/uL, mmol/L, mg/dL
  refMin    Float?  // species-specific reference range min
  refMax    Float?  // species-specific reference range max
  flag      String? // H (high), L (low), N (normal), C (critical)
  sortOrder Int     @default(0)

  labTest LabTest @relation(fields: [labTestId], references: [id], onDelete: Cascade)

  @@index([labTestId])
  @@map("lab_test_results")
}

// ===== Audit Log =====

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, LOGIN_FAILED, EXPORT, ERASE
  entity    String?  // Client, Animal, MedicalRecord, etc.
  entityId  String?
  details   Json?    // Additional context
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===== Refresh Tokens =====

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ===== DICOM / Medical Imaging =====

model DicomStudy {
  id                 String   @id @default(cuid())
  tenantId           String
  animalId           String
  studyInstanceUid   String   @unique
  studyDate          DateTime?
  studyDescription   String?
  modality           String?  // CR, DX, US, CT, MR, OT
  accessionNumber    String?
  referringVet       String?
  orthancStudyId     String?  // Orthanc internal ID for PACS integration
  numberOfSeries     Int      @default(0)
  numberOfInstances  Int      @default(0)
  status             String   @default("received") // received, reviewed, reported
  reportText         String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  animal  Animal       @relation(fields: [animalId], references: [id], onDelete: Cascade)
  series  DicomSeries[]

  @@index([tenantId])
  @@index([tenantId, animalId])
  @@index([orthancStudyId])
  @@map("dicom_studies")
}

model DicomSeries {
  id                String  @id @default(cuid())
  studyId           String
  seriesInstanceUid String  @unique
  seriesNumber      Int?
  seriesDescription String?
  modality          String?
  bodyPart          String?
  orthancSeriesId   String? // Orthanc internal ID
  numberOfInstances Int     @default(0)
  createdAt         DateTime @default(now())

  study     DicomStudy      @relation(fields: [studyId], references: [id], onDelete: Cascade)
  instances DicomInstance[]

  @@index([studyId])
  @@map("dicom_series")
}

model DicomInstance {
  id                String  @id @default(cuid())
  seriesId          String
  sopInstanceUid    String  @unique
  instanceNumber    Int?
  orthancInstanceId String? // Orthanc internal ID
  fileUrl           String? // S3 or local storage path for the DICOM file
  thumbnailUrl      String? // Pre-rendered thumbnail
  createdAt         DateTime @default(now())

  series DicomSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@index([seriesId])
  @@map("dicom_instances")
}

// ===== Animal Documents =====

model Document {
  id         String   @id @default(cuid())
  tenantId   String
  animalId   String
  uploadedBy String
  name       String
  url        String
  key        String
  fileType   String
  fileSize   Int
  notes      String?
  createdAt  DateTime @default(now())

  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploadedBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, animalId])
  @@map("documents")
}
