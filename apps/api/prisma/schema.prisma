generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Multi-Tenant =====

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String
  phone     String?
  address   String?
  logoUrl   String?
  settings  Json     @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  clients      Client[]
  animals      Animal[]
  appointments Appointment[]
  inventory    InventoryItem[]
  suppliers    Supplier[]
  invoices     Invoice[]
  quotes       Quote[]
  reminders    Reminder[]
  messageLogs  MessageLog[]

  @@map("tenants")
}

// ===== Users =====

enum UserRole {
  owner
  admin
  veterinarian
  technician
  receptionist
}

model User {
  id             String   @id @default(cuid())
  tenantId       String
  email          String
  passwordHash   String
  name           String
  phone          String?
  role           UserRole @default(receptionist)
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments   Appointment[] @relation("VeterinarianAppointments")
  medicalRecords MedicalRecord[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ===== Clients (Pet Owners) =====

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  firstName String
  lastName  String
  phone     String
  email     String?
  address   String?
  idNumber  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  animals      Animal[]
  appointments Appointment[]
  invoices     Invoice[]
  quotes       Quote[]
  messageLogs  MessageLog[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, lastName])
  @@map("clients")
}

// ===== Animals =====

enum AnimalSpecies {
  dog
  cat
  bird
  rabbit
  hamster
  reptile
  fish
  other
}

enum AnimalGender {
  male
  female
  unknown
}

model Animal {
  id              String        @id @default(cuid())
  tenantId        String
  clientId        String
  name            String
  species         AnimalSpecies @default(dog)
  breed           String?
  gender          AnimalGender  @default(unknown)
  dateOfBirth     DateTime?
  weight          Float?
  microchipNumber String?
  imageUrl        String?
  isNeutered      Boolean       @default(false)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  reminders      Reminder[]

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, microchipNumber])
  @@map("animals")
}

// ===== Appointments =====

enum AppointmentStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

model Appointment {
  id              String            @id @default(cuid())
  tenantId        String
  clientId        String
  animalId        String
  veterinarianId  String
  startTime       DateTime
  endTime         DateTime
  type            String
  status          AppointmentStatus @default(pending)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  animal        Animal          @relation(fields: [animalId], references: [id], onDelete: Cascade)
  veterinarian  User            @relation("VeterinarianAppointments", fields: [veterinarianId], references: [id])
  medicalRecord MedicalRecord?

  @@index([tenantId])
  @@index([tenantId, veterinarianId, startTime])
  @@index([tenantId, startTime])
  @@map("appointments")
}

// ===== Medical Records =====

model MedicalRecord {
  id              String   @id @default(cuid())
  tenantId        String
  animalId        String
  appointmentId   String?  @unique
  veterinarianId  String
  date            DateTime @default(now())
  diagnosis       String?
  treatment       String?
  prescription    String?
  notes           String?
  weight          Float?
  temperature     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  animal       Animal       @relation(fields: [animalId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])
  veterinarian User         @relation(fields: [veterinarianId], references: [id])

  @@index([tenantId])
  @@index([tenantId, animalId])
  @@map("medical_records")
}

// ===== Inventory =====

enum InventoryCategory {
  medication
  food
  equipment
  supplies
  other
}

model InventoryItem {
  id          String            @id @default(cuid())
  tenantId    String
  name        String
  category    InventoryCategory @default(other)
  sku         String?
  quantity    Int               @default(0)
  minQuantity Int               @default(5)
  unitPrice   Float             @default(0)
  costPrice   Float?
  expiryDate  DateTime?
  supplierId  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  invoiceItems InvoiceItem[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@map("inventory_items")
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     InventoryItem[]

  @@index([tenantId])
  @@map("suppliers")
}

// ===== Invoices =====

enum InvoiceStatus {
  draft
  sent
  paid
  partially_paid
  cancelled
}

enum PaymentMethod {
  cash
  credit_card
  bank_transfer
  check
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  clientId      String
  invoiceNumber String
  status        InvoiceStatus @default(draft)
  subtotal      Float         @default(0)
  taxRate       Float         @default(0.17)
  taxAmount     Float         @default(0)
  total         Float         @default(0)
  paidAmount    Float         @default(0)
  paymentMethod PaymentMethod?
  notes         String?
  issuedAt      DateTime      @default(now())
  dueAt         DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client  Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items   InvoiceItem[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@map("invoices")
}

model InvoiceItem {
  id              String  @id @default(cuid())
  invoiceId       String
  inventoryItemId String?
  description     String
  quantity        Float   @default(1)
  unitPrice       Float
  total           Float

  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@map("invoice_items")
}

// ===== Quotes =====

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

model Quote {
  id          String      @id @default(cuid())
  tenantId    String
  clientId    String
  quoteNumber String
  status      QuoteStatus @default(draft)
  items       Json        @default("[]")
  subtotal    Float       @default(0)
  taxRate     Float       @default(0.17)
  taxAmount   Float       @default(0)
  total       Float       @default(0)
  validUntil  DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@map("quotes")
}

// ===== Reminders =====

enum ReminderType {
  vaccination
  appointment
  follow_up
  custom
}

enum ReminderStatus {
  pending
  sent
  failed
  cancelled
}

model Reminder {
  id         String         @id @default(cuid())
  tenantId   String
  animalId   String?
  type       ReminderType
  status     ReminderStatus @default(pending)
  message    String
  sendAt     DateTime
  sentAt     DateTime?
  channel    String         @default("sms") // sms, email, whatsapp
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  animal Animal? @relation(fields: [animalId], references: [id])

  @@index([tenantId])
  @@index([status, sendAt])
  @@map("reminders")
}

// ===== Message Logs =====

model MessageLog {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String?
  channel   String   // sms, email, whatsapp
  recipient String
  subject   String?
  body      String
  status    String   @default("sent")
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@map("message_logs")
}
