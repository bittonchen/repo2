{
  "name": "vetflow",
  "version": "0.1.0",
  "private": true,
  "description": "VetFlow — SaaS for veterinary clinic management",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:seed": "pnpm --filter api prisma:seed"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "@nestjs/core",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "turbo": "^2.8.17"
  }
}